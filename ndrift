EXIT_OK = 0
EXIT_CHANGES = 1
EXIT_ERROR = 2
BASELINE_VERSION = 1
DEFAULT_CONFIG_PATH = "/etc/ndrift/ndrift.conf"
SIG_ALGO = "hmac-sha256"
SIZE_LIMIT_SENTINEL = "__SIZE_LIMIT__"
SECTION_NAME = "ndrift"


class NdriftError(Exception):
    """Represents an expected ndrift runtime failure."""


@dataclass
class NdriftConfig:
    """Stores typed configuration values for ndrift."""

    config_path: str
    directories: List[str]
    include_patterns: List[str]
    exclude_patterns: List[str]
    baseline_path: str
    signature_path: str
    signature_key_path: str
    state_path: str
    state_signature_path: str
    lock_path: str
    last_report_path: str
    log_path: str
    log_max_bytes: int
    log_backup_count: int
    follow_symlinks: bool
    max_file_size_mb: int
    hash_on_metadata_change_only: bool
    throttle_ms: int
    cron_schedule: str
    email_to: str
    smtp_host: str
    slack_webhook: str
    s3_bucket: str
    allow_read_errors: bool
    scan_updates_baseline: bool


def utc_now() -> str:
    """Returns current UTC time in ISO format."""
    return dt.datetime.now(dt.timezone.utc).replace(microsecond=0).isoformat()


def parse_bool(value: str) -> bool:
    """Converts common boolean strings into a bool."""
    return value.strip().lower() in {"1", "true", "yes", "on"}


def parse_csv(value: str) -> List[str]:
    """Parses a comma separated string into trimmed items."""
    if not value.strip():
        return []
    return [item.strip() for item in value.split(",") if item.strip()]


def normalize_path(path: str) -> str:
    """Expands and normalizes a path to absolute form."""
    return os.path.abspath(os.path.expanduser(path))


def resolve_config_relative_path(config_path: str, value: str) -> str:
    """Resolves a config value path relative to config location."""
    expanded = os.path.expanduser(value)
    if os.path.isabs(expanded):
        return normalize_path(expanded)
    base = os.path.dirname(normalize_path(config_path))
    return normalize_path(os.path.join(base, expanded))


def ensure_parent_dir(path: str) -> None:
    """Creates the parent directory for a path when needed."""
    parent = os.path.dirname(path)
    if parent:
        os.makedirs(parent, exist_ok=True)


def atomic_write_text(path: str, content: str, mode: int = 0o600) -> None:
    """Writes text atomically with restrictive default permissions."""
    ensure_parent_dir(path)
    tmp_path = f"{path}.tmp.{os.getpid()}"
    with open(tmp_path, "w", encoding="utf-8") as handle:
        handle.write(content)
    os.chmod(tmp_path, mode)
    os.replace(tmp_path, path)


def atomic_write_bytes(path: str, content: bytes, mode: int = 0o600) -> None:
    """Writes bytes atomically with restrictive default permissions."""
    ensure_parent_dir(path)
    tmp_path = f"{path}.tmp.{os.getpid()}"
    with open(tmp_path, "wb") as handle:
        handle.write(content)
    os.chmod(tmp_path, mode)
    os.replace(tmp_path, path)


def file_sha256(path: str) -> str:
    """Calculates SHA256 for a file."""
    digest = hashlib.sha256()
    with open(path, "rb") as handle:
        while True:
            chunk = handle.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)
    return digest.hexdigest()


def data_sha256(data: bytes) -> str:
    """Calculates SHA256 for bytes."""
    return hashlib.sha256(data).hexdigest()


def setup_logger(config: NdriftConfig) -> logging.Logger:
    """Creates a console and rotating file logger."""
    logger = logging.getLogger("ndrift")
    logger.setLevel(logging.INFO)
    logger.handlers.clear()
    formatter = logging.Formatter("%(asctime)s %(levelname)s %(message)s")

    stream_handler = logging.StreamHandler(sys.stderr)
    stream_handler.setFormatter(formatter)
    logger.addHandler(stream_handler)

    ensure_parent_dir(config.log_path)
    file_handler = logging.handlers.RotatingFileHandler(
        config.log_path,
        maxBytes=config.log_max_bytes,
        backupCount=config.log_backup_count,
        encoding="utf-8",
    )
    file_handler.setFormatter(formatter)
    logger.addHandler(file_handler)
    return logger


